{
  "name": "@takos/takos-mobile",
  "version": "0.10.33",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "bunx vite --config vite.config.ts",
    "dev:web": "bun run dev",
    "test": "bun test tests",
    "build": "bunx vite build --config vite.config.ts",
    "build:web": "bun run build",
    "check": "tsc --noEmit -p tsconfig.json",
    "mobile:check": "bun run doctor && bun run test && bun run check && bun run build",
    "mobile:doctor": "bun run doctor",
    "mobile:native-release-check": "bun run release:native-check",
    "mobile:release-evidence-check": "bun run release:evidence-check",
    "mobile:release-check": "bun run release:check",
    "mobile:release-status": "bun run release:status",
    "mobile:repo-release-check": "bun run release:repo-check",
    "doctor": "bun ../takosumi/mobile-kit/scripts/check-tauri-mobile.mjs --product takos --scheme takos --product-name Takos --dev-port 1420 --remote-push-plugin mobile-push",
    "release:native-check": "bun ../takosumi/mobile-kit/scripts/check-tauri-mobile-release.mjs --product takos --scheme takos --product-name Takos --dev-port 1420 --remote-push-plugin mobile-push",
    "release:evidence-check": "bun ../takosumi/mobile-kit/scripts/check-mobile-release-evidence.mjs --product takos --product-name Takos --bundle-id jp.takos.mobile",
    "release:check": "bun ../takosumi/mobile-kit/scripts/check-mobile-full-release.mjs",
    "release:status": "bun ../takosumi/mobile-kit/scripts/report-mobile-release-status.mjs --product takos --product-name Takos --bundle-id jp.takos.mobile --require-secure-keystore --require-remote-push --remote-push-backend-file ../takos/src/worker/application/services/notifications/mobile-push-delivery.ts",
    "release:repo-check": "bun scripts/check-mobile-preflight-source-ref.mjs && bun ../takosumi/mobile-kit/scripts/report-mobile-release-status.mjs --product takos --product-name Takos --bundle-id jp.takos.mobile --require-secure-keystore --require-remote-push --remote-push-backend-file ../takos/src/worker/application/services/notifications/mobile-push-delivery.ts --skip-toolchain-probe --fail-on-repo-blockers",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bunx tauri build",
    "tauri:android:init": "bun ../takosumi/mobile-kit/scripts/init-tauri-mobile-native.mjs --platform android --apple-environment development",
    "tauri:android:dev": "bunx tauri android dev --open --host",
    "tauri:android:build": "bunx tauri android build",
    "tauri:native-push:apply": "bun ../takosumi/mobile-kit/scripts/apply-tauri-mobile-push-native.mjs --apple-environment development",
    "tauri:native-push:verify": "bun ../takosumi/mobile-kit/scripts/apply-tauri-mobile-push-native.mjs --apple-environment development --dry-run --strict",
    "tauri:native-push:apply:release": "bun ../takosumi/mobile-kit/scripts/apply-tauri-mobile-push-native.mjs --apple-environment production",
    "tauri:native-push:verify:release": "bun ../takosumi/mobile-kit/scripts/apply-tauri-mobile-push-native.mjs --apple-environment production --dry-run --strict",
    "tauri:ios:init": "bun ../takosumi/mobile-kit/scripts/init-tauri-mobile-native.mjs --platform ios --apple-environment development",
    "tauri:ios:dev": "bunx tauri ios dev",
    "tauri:ios:build": "bunx tauri ios build"
  },
  "dependencies": {
    "@takosjp/takosumi-mobile-kit": "file:../takosumi/mobile-kit",
    "takosumi-contract": "file:../takosumi/contract",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-barcode-scanner": "^2.4.5",
    "@tauri-apps/plugin-biometric": "^2.3.2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.2.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12"
  }
}
