{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Takos",
  "version": "0.10.33",
  "identifier": "jp.takos.mobile",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Takos",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 28
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["takos"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["takos"]
      }
    }
  }
}
